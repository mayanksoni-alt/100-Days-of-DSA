#include <stdio.h>

int main() {
    int n, m;
    scanf("%d", &n);

    int q[n];
    for(int i = 0; i < n; i++) {
        scanf("%d", &q[i]);
    }

    scanf("%d", &m);

    int front = 0;
    int rear = n - 1;
    int size = n;

    for(int i = 0; i < m; i++) {
        if(size > 0) {
            front = (front + 1) % n;
            size--;
        }
    }

    int count = size;
    int i = front;

    while(count--) {
        printf("%d ", q[i]);
        i = (i + 1) % n;
    }

    return 0;
}
