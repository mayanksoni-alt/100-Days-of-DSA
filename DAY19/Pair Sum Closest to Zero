#include <stdio.h>
#include <stdlib.h>

int main(){

    int n;
    scanf("%d", &n);

    int arr[n];
    for(int i=0; i<n; i++)
        scanf("%d", &arr[i]);


    int sum;
    int close = arr[0] + arr[1];
    
    for(int i=0; i<n; i++){
        for(int j=1; j<n; j++){
        sum = arr[i] + arr[j];
        
        if(abs(sum) < abs(close))
            close = sum;
        

        }
    }
    printf("%d\n", close);
    return 0;
}
