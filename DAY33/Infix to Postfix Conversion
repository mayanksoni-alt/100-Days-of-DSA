#include <stdio.h>
#include <ctype.h>
#include <string.h>

int precedence(char ch) {
    if(ch == '+' || ch == '-') return 1;
    if(ch == '*' || ch == '/') return 2;
    return 0;
}

int main() {
    char infix[100], stack[100];
    int top = -1;

    scanf("%s", infix);

    for(int i = 0; i < strlen(infix); i++) {
        char ch = infix[i];

        if(isalnum(ch)) {
            printf("%c", ch);
        }
        else if(ch == '(') {
            stack[++top] = ch;
        }
        else if(ch == ')') {
            while(top >= 0 && stack[top] != '(') {
                printf("%c", stack[top--]);
            }
            top--;
        }
        else {
            while(top >= 0 && precedence(stack[top]) >= precedence(ch)) {
                printf("%c", stack[top--]);
            }
            stack[++top] = ch;
        }
    }

    while(top >= 0) {
        printf("%c", stack[top--]);
    }

    return 0;
}
