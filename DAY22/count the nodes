#include <stdio.h>
#include <stdlib.h>


struct node {
    int data;
    struct node *next;
};

int main(){

    int n;
    scanf("%d", &n);

    struct node *head = NULL, *temp = NULL, *newNode;

    //creating linked list
    for(int i=0; i<n; i++){
        newNode = (struct node*)malloc(sizeof(struct node));
        scanf("%d", &newNode->data);
        newNode->next=NULL;

        if(head == NULL){
            head = newNode;
            temp = newNode;
        }else {
            temp->next=newNode;
            temp = newNode;
        }
    }

    temp = head;
    while(temp != NULL){
        printf("%d ", temp->data);
        temp = temp->next;
    }

    int count=0;
    while(temp != NULL){
        count++;
        temp = temp->next;
    }

    printf("%d", count);
    return 0;
}
