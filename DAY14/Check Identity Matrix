#include <stdio.h>
#include <stdlib.h>

int main(){

    int r, c;
    scanf("%d %d", &r, &c);

    int **matrix=(int**)malloc(r * sizeof(int*));
    for(int i=0; i<r; i++){
        matrix[i] = (int*)malloc(c * sizeof(int));
    }

    if( r != c){
        printf("Not a identity matrix  ");
        return 0;
    }
   
    for(int i=0; i<r; i++){
        for (int j=0; j<c; j++ ){
            scanf("%d", &matrix[i][j]);
        }
    }

    int isIdentity = 1;

    for(int i=0; i<r; i++){
        for(int j=0; j<c; j++){
            if( i == j && matrix[i][j] != 1){
                isIdentity = 0;
                break;
            }
            if(i != j && matrix[i][j] != 0 ){
                isIdentity = 0;
                break;
            }
        }
    }

    if(isIdentity)
        printf("Identity");
    else
        printf("not a identity");
    return 0;
}

