#include <stdio.h>

int main() {
    int m, n;
    scanf("%d %d", &m, &n);

    int num;
    int sum = 0;

    for(int i = 0; i < m; i++){
        for(int j = 0; j < n; j++){
            scanf("%d", &num);

            if(i == j){
                sum += num;
            }
        }
    }

    printf("%d", sum);

    return 0;
}
